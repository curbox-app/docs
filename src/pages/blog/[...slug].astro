---
/**
 * Dynamic blog post page — renders individual blog entries.
 */
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, updatedDate, author, tags } = post.data;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — Curbox Blog`} />
    <meta property="og:description" content={description} />
    <title>{title} — Curbox Blog</title>
    <link rel="alternate" type="application/rss+xml" href="/blog/rss.xml" title="Curbox Blog RSS Feed" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', system-ui, sans-serif; background: #F9F9F9; color: #333333; -webkit-font-smoothing: antialiased; }

      /* Prose styles */
      .prose { max-width: 68ch; margin: 0 auto; line-height: 1.75; }
      .prose h1, .prose h2, .prose h3, .prose h4 {
        font-family: 'Merriweather', Georgia, serif;
        font-weight: 700;
        letter-spacing: -0.015em;
        line-height: 1.3;
        margin-top: 2em;
        margin-bottom: 0.75em;
        color: #222222;
      }
      .prose h1 { font-size: 2rem; }
      .prose h2 { font-size: 1.5rem; }
      .prose h3 { font-size: 1.2rem; }
      .prose p { margin-bottom: 1.25em; color: #444444; }
      .prose a { color: #8A9A5B; text-decoration: underline; text-underline-offset: 3px; }
      .prose a:hover { color: #7A8A4B; }
      .prose ul, .prose ol { padding-left: 1.5em; margin-bottom: 1.25em; color: #444444; }
      .prose li { margin-bottom: 0.5em; }
      .prose blockquote {
        border-left: 3px solid #8A9A5B;
        padding: 0.75em 1.25em;
        margin: 1.5em 0;
        background: #EEF2E6;
        border-radius: 0 0.5rem 0.5rem 0;
        color: #555555;
        font-style: italic;
      }
      .prose code {
        background: #EEF2E6;
        color: #5a6a3b;
        padding: 0.15em 0.4em;
        border-radius: 0.25em;
        font-size: 0.875em;
      }
      .prose pre {
        background: #1e2118;
        color: #d0d8c0;
        padding: 1.25em 1.5em;
        border-radius: 0.75em;
        overflow-x: auto;
        margin-bottom: 1.5em;
        font-size: 0.875em;
        line-height: 1.65;
      }
      .prose pre code { background: none; color: inherit; padding: 0; font-size: 1em; }
      .prose hr { border: none; border-top: 1px solid #E5E7EB; margin: 2.5em 0; }
      .prose img { border-radius: 0.75rem; max-width: 100%; }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </head>
  <body style="background:#F9F9F9;color:#333333;min-height:100vh;">

    <!-- Nav -->
    <header style="position:sticky;top:0;z-index:50;background:rgba(249,249,249,0.85);backdrop-filter:blur(8px);border-bottom:1px solid #E5E7EB;">
      <nav style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;">
        <a href="/" style="font-weight:600;font-size:1.1rem;color:#333333;text-decoration:none;display:flex;align-items:center;gap:0.5rem;">
          <svg style="width:1.5rem;height:1.5rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#8A9A5B"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-9 5.25-9-5.25v-2.25"/></svg>
          Curbox
        </a>
        <div style="display:flex;gap:1.5rem;font-size:0.875rem;font-weight:500;">
          <a href="/getting-started/installation/" style="color:#666666;text-decoration:none;">Docs</a>
          <a href="/blog/" style="color:#8A9A5B;text-decoration:none;">Blog</a>
          <a href="/about/" style="color:#666666;text-decoration:none;">About</a>
        </div>
      </nav>
    </header>

    <main style="padding:3rem 1.5rem 5rem;">

      <!-- Breadcrumb -->
      <div style="max-width:68ch;margin:0 auto 2rem;font-size:0.8rem;color:#999999;">
        <a href="/blog/" style="color:#8A9A5B;text-decoration:none;">← All posts</a>
      </div>

      <!-- Article header -->
      <header style="max-width:68ch;margin:0 auto 3rem;">
        <!-- Tags -->
        {tags.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;">
            {tags.map((tag: string) => (
              <span style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#8A9A5B;background:#EEF2E6;padding:0.125rem 0.5rem;border-radius:9999px;">{tag}</span>
            ))}
          </div>
        )}

        <h1 style="font-family:'Merriweather',Georgia,serif;font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;color:#222222;letter-spacing:-0.02em;line-height:1.25;margin-bottom:1rem;">{title}</h1>
        <p style="font-size:1.125rem;color:#666666;line-height:1.65;margin-bottom:1.5rem;">{description}</p>

        <div style="display:flex;align-items:center;gap:0.75rem;font-size:0.85rem;color:#999999;padding-bottom:1.5rem;border-bottom:1px solid #E5E7EB;">
          <span>By <strong style="color:#666666;">{author}</strong></span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          {updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>Updated <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
            </>
          )}
        </div>
      </header>

      <!-- Article body -->
      <article class="prose">
        <Content />
      </article>

      <!-- Back link -->
      <div style="max-width:68ch;margin:3rem auto 0;padding-top:1.5rem;border-top:1px solid #E5E7EB;">
        <a href="/blog/" style="color:#8A9A5B;font-weight:500;text-decoration:none;font-size:0.9rem;">← Back to all posts</a>
      </div>

    </main>

    <footer style="border-top:1px solid #E5E7EB;background:#F9F9F9;padding:2.5rem 1.5rem;">
      <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;font-size:0.875rem;color:#999999;">
        <p>&copy; {new Date().getFullYear()} Curbox Contributors — Apache 2.0 License</p>
        <a href="/" style="color:#999999;text-decoration:none;">← Back to home</a>
      </div>
    </footer>

  </body>
</html>
