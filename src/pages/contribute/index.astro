---
/**
 * Contribute / FOSS page — how to get involved
 */
const pageTitle = 'Contribute to Curbox — Join the FOSS Community';
const pageDesc = 'Help build Curbox: translate the app, submit bug reports, write code, or donate.';
const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
const canonicalURL = new URL(`${base}contribute/`, 'https://curbox-app.github.io').href;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Curbox" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', system-ui, sans-serif; background: #F9F9F9; color: #333333; -webkit-font-smoothing: antialiased; }
      .prose { max-width: 68ch; margin: 0 auto; line-height: 1.75; }
      .prose h2 { font-family: 'Merriweather', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: #222; margin: 2.5em 0 0.75em; letter-spacing: -0.015em; }
      .prose p { margin-bottom: 1.25em; color: #444444; }
      .prose a { color: #8A9A5B; text-decoration: underline; text-underline-offset: 3px; }
      .prose ul, .prose ol { padding-left: 1.5em; margin-bottom: 1.25em; color: #444444; }
      .prose li { margin-bottom: 0.5em; }
    </style>
  </head>
  <body style="background:#F9F9F9;color:#333333;min-height:100vh;">

    <header style="position:sticky;top:0;z-index:50;background:rgba(249,249,249,0.85);backdrop-filter:blur(8px);border-bottom:1px solid #E5E7EB;">
      <nav style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;">
        <a href={base} style="font-weight:600;font-size:1.1rem;color:#333333;text-decoration:none;display:flex;align-items:center;gap:0.5rem;">
          <svg style="width:1.5rem;height:1.5rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#8A9A5B"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-9 5.25-9-5.25v-2.25"/></svg>
          Curbox
        </a>
        <div style="display:flex;gap:1.5rem;font-size:0.875rem;font-weight:500;color:#666666;">
          <a href={`${base}getting-started/installation/`} style="color:#666666;text-decoration:none;">Docs</a>
          <a href={`${base}blog/`} style="color:#666666;text-decoration:none;">Blog</a>
          <a href={`${base}about/`} style="color:#666666;text-decoration:none;">About</a>
          <a href={`${base}contribute/`} style="color:#8A9A5B;text-decoration:none;">Contribute</a>
        </div>
      </nav>
    </header>

    <main style="padding:4rem 1.5rem 6rem;">
      <div style="max-width:68ch;margin:0 auto;">
        <h1 style="font-family:'Merriweather',Georgia,serif;font-size:clamp(2rem,4vw,2.75rem);font-weight:700;color:#222222;letter-spacing:-0.02em;line-height:1.2;margin-bottom:1.5rem;">
          Contribute to Curbox
        </h1>
        <p style="font-size:1.125rem;color:#555555;line-height:1.7;margin-bottom:3rem;max-width:52ch;">
          Curbox is built by its community. There are many ways to help — from writing a single sentence to submitting a pull request.
        </p>
      </div>

      <!-- Ways to contribute cards -->
      <div style="max-width:1000px;margin:0 auto 4rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;">

        <!-- Code -->
        <div style="background:#FFFFFF;border:1px solid #E5E7EB;border-radius:1rem;padding:1.5rem;">
          <div style="color:#8A9A5B;margin-bottom:1rem;">
            <svg style="width:2rem;height:2rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>
          </div>
          <h3 style="font-weight:600;font-size:1.05rem;color:#333333;margin-bottom:0.5rem;">Write Code</h3>
          <p style="font-size:0.875rem;color:#666666;line-height:1.65;margin-bottom:1rem;">Fix bugs, implement features, or improve performance. Check the <a href="https://github.com/curbox-app/curbox/issues?q=is%3Aissue+is%3Aopen+label%3A%22good+first+issue%22" style="color:#8A9A5B;">good first issues</a> for a welcoming entry point.</p>
          <a href="https://github.com/curbox-app/curbox/blob/main/CONTRIBUTING.md" style="font-size:0.875rem;font-weight:500;color:#8A9A5B;text-decoration:none;">Contributing guide →</a>
        </div>

        <!-- Translate -->
        <div style="background:#FFFFFF;border:1px solid #E5E7EB;border-radius:1rem;padding:1.5rem;">
          <div style="color:#8A9A5B;margin-bottom:1rem;">
            <svg style="width:2rem;height:2rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802"/></svg>
          </div>
          <h3 style="font-weight:600;font-size:1.05rem;color:#333333;margin-bottom:0.5rem;">Translate</h3>
          <p style="font-size:0.875rem;color:#666666;line-height:1.65;margin-bottom:1rem;">Help bring Curbox to users in your language. Translations are managed through our Weblate project — no coding required.</p>
          <a href="https://github.com/curbox-app/curbox/blob/main/CONTRIBUTING.md#translations" style="font-size:0.875rem;font-weight:500;color:#8A9A5B;text-decoration:none;">Start translating →</a>
        </div>

        <!-- Bug reports -->
        <div style="background:#FFFFFF;border:1px solid #E5E7EB;border-radius:1rem;padding:1.5rem;">
          <div style="color:#8A9A5B;margin-bottom:1rem;">
            <svg style="width:2rem;height:2rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75c1.148 0 2.278.08 3.383.237 1.037.146 1.866.966 1.866 2.013 0 3.728-2.35 6.75-5.25 6.75S6.75 18.728 6.75 15c0-1.046.83-1.867 1.866-2.013A24.204 24.204 0 0 1 12 12.75Zm0 0c2.883 0 5.647.508 8.207 1.44a23.91 23.91 0 0 1-1.152 6.06M12 12.75c-2.883 0-5.647.508-8.208 1.44a23.916 23.916 0 0 0 1.152 6.061M12 12.75a2.25 2.25 0 0 0 2.248-2.354M12 12.75a2.25 2.25 0 0 1-2.248-2.354M12 8.25c.995 0 1.971-.08 2.922-.236.403-.066.74-.358.795-.762a3.778 3.778 0 0 0-.399-2.25M12 8.25c-.995 0-1.97-.08-2.922-.236-.402-.066-.74-.358-.795-.762a3.734 3.734 0 0 1 .4-2.253M12 8.25a2.25 2.25 0 0 0-2.248 2.146M12 8.25a2.25 2.25 0 0 1 2.248 2.146M8.683 5a6.032 6.032 0 0 1-1.155-1.002c.07-.63.27-1.222.574-1.747m.581 2.749A3.75 3.75 0 0 1 15.318 5m0 0c.427-.283.815-.62 1.155-.999a4.471 4.471 0 0 0-.575-1.752M4.921 6a24.048 24.048 0 0 0-.392 3.314c1.668.546 3.416.914 5.223 1.082M19.08 6c.205 1.08.337 2.187.392 3.314a23.882 23.882 0 0 1-5.223 1.082"/></svg>
          </div>
          <h3 style="font-weight:600;font-size:1.05rem;color:#333333;margin-bottom:0.5rem;">Report Bugs</h3>
          <p style="font-size:0.875rem;color:#666666;line-height:1.65;margin-bottom:1rem;">Found something broken? A detailed bug report is one of the most valuable contributions you can make. Use the issue template for best results.</p>
          <a href="https://github.com/curbox-app/curbox/issues/new?template=bug_report.md" style="font-size:0.875rem;font-weight:500;color:#8A9A5B;text-decoration:none;">File a bug →</a>
        </div>

        <!-- Docs -->
        <div style="background:#FFFFFF;border:1px solid #E5E7EB;border-radius:1rem;padding:1.5rem;">
          <div style="color:#8A9A5B;margin-bottom:1rem;">
            <svg style="width:2rem;height:2rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </div>
          <h3 style="font-weight:600;font-size:1.05rem;color:#333333;margin-bottom:0.5rem;">Improve the Docs</h3>
          <p style="font-size:0.875rem;color:#666666;line-height:1.65;margin-bottom:1rem;">Notice a typo, a gap in our tutorials, or something confusing? Every doc page has an "Edit on GitHub" link — small fixes are warmly welcome.</p>
          <a href="https://github.com/curbox-app/blogs" style="font-size:0.875rem;font-weight:500;color:#8A9A5B;text-decoration:none;">Edit the docs repo →</a>
        </div>

      </div>

      <article class="prose">
        <h2>Code of Conduct</h2>
        <p>
          Curbox follows the <a href="https://www.contributor-covenant.org/version/2/1/code_of_conduct/">Contributor Covenant v2.1</a>. We are committed to a welcoming, inclusive community. Harassment of any kind is not tolerated.
        </p>

        <h2>How Contributions are Reviewed</h2>
        <ol>
          <li>Fork the repository and create a branch from <code>main</code>.</li>
          <li>Make your changes, following the coding style in the project.</li>
          <li>Open a Pull Request with a clear description of the change and why it is needed.</li>
          <li>A maintainer will review and provide feedback within 7 days.</li>
          <li>Once approved, your contribution will be merged and credited in the changelog.</li>
        </ol>

        <h2>Other Ways to Help</h2>
        <ul>
          <li><strong>Star the repo</strong> on GitHub — it helps others discover Curbox.</li>
          <li><strong>Share Curbox</strong> with someone who might benefit from it.</li>
          <li><strong>Write about your experience</strong> — blog posts and reviews help the community.</li>
        </ul>
      </article>
    </main>

    <footer style="border-top:1px solid #E5E7EB;background:#F9F9F9;padding:2.5rem 1.5rem;">
      <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;font-size:0.875rem;color:#999999;">
        <p>&copy; {new Date().getFullYear()} Curbox Contributors — Apache 2.0 License</p>
        <a href={base} style="color:#999999;text-decoration:none;">← Back to home</a>
      </div>
    </footer>

  </body>
</html>
