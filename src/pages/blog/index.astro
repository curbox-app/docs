---
/**
 * Blog index page — lists all published posts
 */
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = 'Blog — Curbox';
const pageDesc = 'Insights on digital well-being, mindful technology use, and the science of focus.';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>
    <link rel="alternate" type="application/rss+xml" href="/blog/rss.xml" title="Curbox Blog RSS Feed" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', system-ui, sans-serif; background: #F9F9F9; color: #333333; -webkit-font-smoothing: antialiased; }
    </style>
  </head>
  <body style="background:#F9F9F9;color:#333333;min-height:100vh;">

    <!-- Nav -->
    <header style="position:sticky;top:0;z-index:50;background:rgba(249,249,249,0.85);backdrop-filter:blur(8px);border-bottom:1px solid #E5E7EB;">
      <nav style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;">
        <a href="/" style="font-weight:600;font-size:1.1rem;color:#333333;text-decoration:none;display:flex;align-items:center;gap:0.5rem;">
          <svg style="width:1.5rem;height:1.5rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#8A9A5B"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-9 5.25-9-5.25v-2.25"/></svg>
          Curbox
        </a>
        <div style="display:flex;gap:1.5rem;font-size:0.875rem;font-weight:500;color:#666666;">
          <a href="/getting-started/installation/" style="color:#666666;text-decoration:none;">Docs</a>
          <a href="/blog/" style="color:#8A9A5B;text-decoration:none;">Blog</a>
          <a href="/about/" style="color:#666666;text-decoration:none;">About</a>
        </div>
      </nav>
    </header>

    <main style="max-width:1100px;margin:0 auto;padding:4rem 1.5rem;">
      <!-- Header -->
      <div style="margin-bottom:3rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
          <a href="/blog/rss.xml" style="display:inline-flex;align-items:center;gap:0.375rem;font-size:0.75rem;font-weight:600;color:#8A9A5B;text-decoration:none;background:#EEF2E6;padding:0.25rem 0.75rem;border-radius:9999px;">
            <svg style="width:0.875rem;height:0.875rem;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
            RSS Feed
          </a>
        </div>
        <h1 style="font-family:'Merriweather',Georgia,serif;font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;color:#333333;margin-bottom:0.75rem;letter-spacing:-0.02em;">Digital Well-being Insights</h1>
        <p style="color:#666666;max-width:52ch;line-height:1.7;">Thoughts on mindful technology, the science of focus, and building healthier digital habits.</p>
      </div>

      <!-- Post list -->
      {posts.length === 0 ? (
        <p style="color:#999999;">No posts published yet. Check back soon.</p>
      ) : (
        <ul style="list-style:none;display:flex;flex-direction:column;gap:2rem;">
          {posts.map((post) => (
            <li>
              <article style="background:#FFFFFF;border:1px solid #E5E7EB;border-radius:1rem;padding:1.75rem;">
                {post.data.tags.length > 0 && (
                  <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.75rem;">
                    {post.data.tags.map((tag: string) => (
                      <span style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#8A9A5B;background:#EEF2E6;padding:0.125rem 0.5rem;border-radius:9999px;">{tag}</span>
                    ))}
                  </div>
                )}
                <h2 style="font-family:'Merriweather',Georgia,serif;font-size:1.25rem;font-weight:700;color:#333333;margin-bottom:0.5rem;letter-spacing:-0.015em;">
                  <a href={`/blog/${post.slug}/`} style="color:inherit;text-decoration:none;">{post.data.title}</a>
                </h2>
                <p style="color:#666666;font-size:0.9rem;line-height:1.65;margin-bottom:1rem;">{post.data.description}</p>
                <div style="display:flex;align-items:center;justify-content:space-between;font-size:0.8rem;color:#999999;">
                  <span>
                    By <strong style="color:#666666;">{post.data.author}</strong> &mdash;
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </span>
                  <a href={`/blog/${post.slug}/`} style="color:#8A9A5B;font-weight:500;text-decoration:none;">Read →</a>
                </div>
              </article>
            </li>
          ))}
        </ul>
      )}
    </main>

    <footer style="border-top:1px solid #E5E7EB;background:#F9F9F9;padding:2.5rem 1.5rem;margin-top:4rem;">
      <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;font-size:0.875rem;color:#999999;">
        <p>&copy; {new Date().getFullYear()} Curbox Contributors — Apache 2.0 License</p>
        <a href="/" style="color:#999999;text-decoration:none;">← Back to home</a>
      </div>
    </footer>

  </body>
</html>
