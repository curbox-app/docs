---
/**
 * Curbox – Custom Landing Page
 * Minimalist, calming design using Tailwind CSS.
 * Designed to lower cognitive load and guide visitors toward docs or download.
 */

/** Update this when releasing a new version. */
const LATEST_VERSION = 'v1.2.0';

const benefits = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`,
    title: 'App Time Limits',
    description: 'Set gentle, enforceable daily limits on any app. Curbox nudges you before you hit them.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    title: 'Deep Work Mode',
    description: 'Lock distracting apps for a chosen duration so you can enter a state of deep, uninterrupted focus.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>`,
    title: 'Honest Analytics',
    description: 'A clear, honest view of your daily screentime — without judgement, just insight.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>`,
    title: '100% Free & Open Source',
    description: 'No subscriptions, no ads, no data harvesting. Curbox is FOSS — inspect every line of code.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/></svg>`,
    title: 'Calming UI',
    description: 'A thoughtfully designed interface that itself is calm — no dark patterns or guilt-tripping.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
    title: 'Privacy First',
    description: 'All data stays on your device. Curbox never phones home.',
  },
];

const siteTitle = 'Curbox';
const siteDescription = 'Regain your focus. A free, open-source Android app for mindful screentime management and digital well-being.';
import { base } from '../utils/base-url';
const canonicalURL = new URL(base, 'https://curbox-app.github.io').href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${canonicalURL}#organization`,
      name: 'Curbox',
      url: canonicalURL,
      logo: {
        '@type': 'ImageObject',
        url: `${canonicalURL}favicon.svg`,
      },
      sameAs: [
        'https://github.com/curbox-app/curbox',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${canonicalURL}#website`,
      url: canonicalURL,
      name: siteTitle,
      description: siteDescription,
      publisher: { '@id': `${canonicalURL}#organization` },
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Curbox',
      operatingSystem: 'Android',
      applicationCategory: 'UtilitiesApplication',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      description: siteDescription,
      url: canonicalURL,
      downloadUrl: 'https://github.com/curbox-app/curbox/releases/latest',
      license: 'https://www.apache.org/licenses/LICENSE-2.0',
    },
  ],
};
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:title" content={`${siteTitle} — Mindful Screentime for Android`} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteTitle} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${siteTitle} — Mindful Screentime for Android`} />
    <meta name="twitter:description" content={siteDescription} />
    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" href={`${base}blog/rss.xml`} title="Curbox Blog RSS Feed" />
    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href={`${base}sitemap-index.xml`} />
    <meta name="theme-color" content="#8A9A5B" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{siteTitle} — Mindful Screentime for Android</title>
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Google Fonts: Inter + Merriweather -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Merriweather:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Inline critical CSS to avoid layout shift */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: #F9F9F9;
        color: #333333;
        -webkit-font-smoothing: antialiased;
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
        html { scroll-behavior: auto; }
      }
    </style>
  </head>

  <body class="bg-cb-bg text-cb-text">

    <!-- ── NAV ─────────────────────────────────── -->
    <header class="sticky top-0 z-50 bg-cb-bg/80 backdrop-blur-md border-b border-cb-border">
      <nav class="max-w-layout mx-auto flex items-center justify-between px-6 py-4">
        <!-- Logo wordmark -->
        <a href={base} class="flex items-center gap-2 font-semibold text-lg text-cb-text no-underline">
          <svg class="w-7 h-7 text-cb-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-9 5.25-9-5.25v-2.25" />
          </svg>
          <span>Curbox</span>
        </a>

        <!-- Desktop nav -->
        <ul class="hidden md:flex items-center gap-7 text-sm font-medium text-cb-text-muted list-none">
          <li><a href={`${base}getting-started/installation/`} class="hover:text-cb-accent transition-colors duration-200">Docs</a></li>
          <li><a href={`${base}blog/`} class="hover:text-cb-accent transition-colors duration-200">Blog</a></li>
          <li><a href={`${base}about/`} class="hover:text-cb-accent transition-colors duration-200">About</a></li>
          <li><a href={`${base}contribute/`} class="hover:text-cb-accent transition-colors duration-200">Contribute</a></li>
        </ul>

        <!-- CTA button -->
        <a
          href="https://github.com/curbox-app/curbox/releases/latest"
          class="hidden md:inline-flex items-center gap-2 bg-cb-accent text-white text-sm font-semibold px-4 py-2 rounded-xl hover:bg-cb-accent-hover transition-colors duration-200 no-underline"
          aria-label="Download Curbox APK from GitHub Releases"
        >
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Download
        </a>
      </nav>
    </header>

    <main>

      <!-- ── HERO ────────────────────────────────── -->
      <section class="relative overflow-hidden py-24 md:py-36 px-6">
        <!-- Subtle radial gradient backdrop -->
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,#eef2e6_0%,transparent_70%)]" aria-hidden="true"></div>

        <div class="relative max-w-layout mx-auto text-center">
          <!-- Eyebrow badge -->
          <span class="inline-flex items-center gap-1.5 bg-cb-accent-light text-cb-accent text-xs font-semibold px-3 py-1 rounded-full mb-6 tracking-wide uppercase">
            <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
            Free & Open Source · Android
          </span>

          <!-- Headline -->
          <h1 class="font-serif text-display text-cb-text mb-6 max-w-3xl mx-auto" style="font-family:'Merriweather',Georgia,serif;">
            Reclaim your attention.<br />
            <span class="text-cb-accent">One screen at a time.</span>
          </h1>

          <!-- Sub-headline -->
          <p class="text-lg md:text-xl text-cb-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
            Curbox is a calm, FOSS Android app that helps you build a healthier relationship with your devices — no dark patterns, no subscriptions.
          </p>

          <!-- CTA cluster -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://github.com/curbox-app/curbox/releases/latest"
              class="inline-flex items-center gap-2 bg-cb-accent text-white font-semibold px-7 py-3.5 rounded-xl shadow-sm hover:bg-cb-accent-hover transition-colors duration-200 no-underline text-base"
            >
              <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download the App
            </a>
            <a
              href={`${base}getting-started/installation/`}
              class="inline-flex items-center gap-2 bg-white border border-cb-border text-cb-text font-semibold px-7 py-3.5 rounded-xl shadow-sm hover:border-cb-accent hover:text-cb-accent transition-colors duration-200 no-underline text-base"
            >
              <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
              Read the Docs
            </a>
          </div>

          <!-- Social proof / release tag -->
          <p class="mt-8 text-sm text-cb-text-subtle">
            Latest release:
            <a href="https://github.com/curbox-app/curbox/releases" class="text-cb-accent hover:underline">{LATEST_VERSION}</a>
            &mdash; Apache 2.0 License
          </p>
        </div>
      </section>

      <!-- ── BENEFITS GRID ──────────────────────── -->
      <section class="py-20 px-6 bg-white" aria-labelledby="benefits-heading">
        <div class="max-w-layout mx-auto">
          <!-- Section header -->
          <div class="text-center mb-14">
            <h2 id="benefits-heading" class="font-serif text-heading text-cb-text mb-4" style="font-family:'Merriweather',Georgia,serif;">
              Everything you need to focus better
            </h2>
            <p class="text-cb-text-muted max-w-xl mx-auto leading-relaxed">
              Curbox is purposefully simple. A small set of powerful tools, designed with restraint.
            </p>
          </div>

          <!-- Grid -->
          <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 list-none">
            {benefits.map((benefit) => (
              <li class="bg-cb-bg border border-cb-border rounded-2xl p-6 hover:border-cb-accent/40 hover:shadow-sm transition-all duration-300">
                <div class="w-10 h-10 text-cb-accent mb-4" set:html={benefit.icon} />
                <h3 class="font-semibold text-cb-text mb-2 text-[1.05rem]">{benefit.title}</h3>
                <p class="text-sm text-cb-text-muted leading-relaxed">{benefit.description}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ── PHILOSOPHY BAND ────────────────────── -->
      <section class="py-20 px-6 bg-cb-accent-light" aria-labelledby="philosophy-heading">
        <div class="max-w-prose-wide mx-auto text-center">
          <blockquote class="not-italic">
            <p class="font-serif text-2xl md:text-3xl text-cb-text leading-snug mb-6" style="font-family:'Merriweather',Georgia,serif;">
              &ldquo;The phone is not the enemy. Mindlessness is. Curbox helps you be intentional.&rdquo;
            </p>
            <footer class="text-sm font-medium text-cb-accent uppercase tracking-widest">
              — The Curbox Philosophy
            </footer>
          </blockquote>
        </div>
      </section>

      <!-- ── DUAL CTA ────────────────────────────── -->
      <section class="py-20 px-6 bg-white" aria-labelledby="cta-heading">
        <div class="max-w-layout mx-auto">
          <h2 id="cta-heading" class="sr-only">Next steps</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Card: Docs -->
            <div class="relative bg-cb-bg border border-cb-border rounded-2xl p-8 flex flex-col gap-4 hover:shadow-md transition-shadow duration-300">
              <div class="w-10 h-10 text-cb-accent">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-xl text-cb-text mb-2">Read the Documentation</h3>
                <p class="text-cb-text-muted text-sm leading-relaxed">Step-by-step guides from installation to advanced Shizuku configuration.</p>
              </div>
              <a
              href={`${base}getting-started/installation/`}
                class="mt-auto inline-flex items-center gap-1.5 text-cb-accent font-semibold text-sm hover:underline no-underline"
                aria-label="Read the Curbox documentation"
              >
                Go to Docs
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>

            <!-- Card: Blog -->
            <div class="relative bg-cb-bg border border-cb-border rounded-2xl p-8 flex flex-col gap-4 hover:shadow-md transition-shadow duration-300">
              <div class="w-10 h-10 text-cb-accent">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-xl text-cb-text mb-2">Explore the Blog</h3>
                <p class="text-cb-text-muted text-sm leading-relaxed">Insights on digital well-being, dopamine detoxes, and the science of focus.</p>
              </div>
              <a
              href={`${base}blog/`}
                class="mt-auto inline-flex items-center gap-1.5 text-cb-accent font-semibold text-sm hover:underline no-underline"
                aria-label="Explore the Curbox blog"
              >
                Read the Blog
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>

          </div>
        </div>
      </section>

    </main>

    <!-- ── FOOTER ──────────────────────────────── -->
    <footer class="border-t border-cb-border bg-cb-bg py-10 px-6">
      <div class="max-w-layout mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-cb-text-subtle">
        <p>
          &copy; {new Date().getFullYear()} Curbox Contributors &mdash;
          <a href="https://www.apache.org/licenses/LICENSE-2.0" class="hover:text-cb-accent transition-colors duration-200">Apache 2.0 License</a>
        </p>
        <nav class="flex items-center gap-5" aria-label="Footer navigation">
          <a href={`${base}getting-started/installation/`} class="hover:text-cb-accent transition-colors duration-200">Docs</a>
          <a href={`${base}blog/`} class="hover:text-cb-accent transition-colors duration-200">Blog</a>
          <a href={`${base}about/`} class="hover:text-cb-accent transition-colors duration-200">About</a>
          <a href={`${base}contribute/`} class="hover:text-cb-accent transition-colors duration-200">Contribute</a>
          <a href="https://github.com/curbox-app/curbox" class="hover:text-cb-accent transition-colors duration-200" aria-label="Curbox on GitHub">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577v-2.165c-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.838 1.237 1.838 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.776.419-1.305.762-1.605-2.665-.304-5.467-1.334-5.467-5.931 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.3 1.23a11.51 11.51 0 0 1 3.003-.404c1.02.005 2.046.137 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.653 1.652.242 2.873.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .322.218.694.825.576C20.565 21.796 24 17.3 24 12c0-6.627-5.373-12-12-12Z"/>
            </svg>
          </a>
