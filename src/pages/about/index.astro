---
/**
 * About page — the FOSS mission behind Curbox
 */
const pageTitle = 'About Curbox — The FOSS Mission';
const pageDesc = 'Why Curbox was built, the team behind it, and the open source philosophy that drives it.';
import { base } from '../../utils/base-url';
const canonicalURL = new URL(`${base}about/`, 'https://curbox-app.github.io').href;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Curbox" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Inter', system-ui, sans-serif; background: #F9F9F9; color: #333333; -webkit-font-smoothing: antialiased; }
      .prose { max-width: 68ch; margin: 0 auto; line-height: 1.75; }
      .prose h2 { font-family: 'Merriweather', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: #222; margin: 2.5em 0 0.75em; letter-spacing: -0.015em; }
      .prose p { margin-bottom: 1.25em; color: #444444; }
      .prose a { color: #8A9A5B; text-decoration: underline; text-underline-offset: 3px; }
      .prose ul { padding-left: 1.5em; margin-bottom: 1.25em; color: #444444; }
      .prose li { margin-bottom: 0.5em; }
    </style>
  </head>
  <body style="background:#F9F9F9;color:#333333;min-height:100vh;">

    <header style="position:sticky;top:0;z-index:50;background:rgba(249,249,249,0.85);backdrop-filter:blur(8px);border-bottom:1px solid #E5E7EB;">
      <nav style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;">
        <a href={base} style="font-weight:600;font-size:1.1rem;color:#333333;text-decoration:none;display:flex;align-items:center;gap:0.5rem;">
          <svg style="width:1.5rem;height:1.5rem;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#8A9A5B"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-9 5.25-9-5.25v-2.25"/></svg>
          Curbox
        </a>
        <div style="display:flex;gap:1.5rem;font-size:0.875rem;font-weight:500;color:#666666;">
          <a href={`${base}getting-started/installation/`} style="color:#666666;text-decoration:none;">Docs</a>
          <a href={`${base}blog/`} style="color:#666666;text-decoration:none;">Blog</a>
          <a href={`${base}about/`} style="color:#8A9A5B;text-decoration:none;">About</a>
          <a href={`${base}contribute/`} style="color:#666666;text-decoration:none;">Contribute</a>
        </div>
      </nav>
    </header>

    <main style="padding:4rem 1.5rem 6rem;">
      <div style="max-width:68ch;margin:0 auto;">
        <h1 style="font-family:'Merriweather',Georgia,serif;font-size:clamp(2rem,4vw,2.75rem);font-weight:700;color:#222222;letter-spacing:-0.02em;line-height:1.2;margin-bottom:1.5rem;">
          Why we built Curbox
        </h1>
        <p style="font-size:1.125rem;color:#555555;line-height:1.7;margin-bottom:3rem;max-width:52ch;">
          A FOSS project born out of frustration with manipulative app ecosystems — and a belief that technology should serve people, not exploit them.
        </p>
      </div>

      <article class="prose">

        <h2>The Problem</h2>
        <p>
          The modern smartphone is engineered for addiction. Infinite scrolls, variable-reward notifications, streak mechanics — every major platform employs these patterns to maximize engagement at the direct expense of your focus, sleep, and mental health.
        </p>
        <p>
          Screentime management tools exist, but almost all of them are either built into the same walled gardens profiting from your attention, or they are paid, closed-source apps with their own monetization pressures.
        </p>

        <h2>Our Answer</h2>
        <p>
          Curbox was created on a simple premise: <strong>you should be able to own and control the tool that helps you control your phone.</strong>
        </p>
        <p>
          Curbox is <a href="https://github.com/curbox-app/curbox">fully open source</a> under the Apache 2.0 license. Every line of code is public. There are no ads, no analytics pinging external servers, no subscription walls. Your data never leaves your device.
        </p>

        <h2>The FOSS Philosophy</h2>
        <p>
          We believe Free and Open Source Software is not just a development model — it is an ethical stance. When software that touches your most personal habits is open, it becomes:
        </p>
        <ul>
          <li><strong>Auditable</strong> — anyone can verify what the app actually does.</li>
          <li><strong>Forkable</strong> — if we ever lost our way, the community could carry the project.</li>
          <li><strong>Community-driven</strong> — improvements come from people who use it, not from growth metrics.</li>
        </ul>

        <h2>The Design Philosophy</h2>
        <p>
          We believe a tool for reducing digital noise should not itself add to that noise. Curbox's UI is deliberately calm and minimal. No dark patterns, no guilt-tripping streak counters, no gamification. Just clear, honest information and gentle, effective controls.
        </p>

        <h2>Who Built This</h2>
        <p>
          Curbox was started by a small group of developers who were frustrated enough with their own phone habits to do something about it. We are not a company. We do not have investors. We have contributors.
        </p>
        <p>
          <a href={`${base}contribute/`}>Join us. →</a>
        </p>

      </article>
    </main>

    <footer style="border-top:1px solid #E5E7EB;background:#F9F9F9;padding:2.5rem 1.5rem;">
      <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;font-size:0.875rem;color:#999999;">
        <p>&copy; {new Date().getFullYear()} Curbox Contributors — Apache 2.0 License</p>
        <a href={base} style="color:#999999;text-decoration:none;">← Back to home</a>
      </div>
    </footer>

  </body>
</html>
